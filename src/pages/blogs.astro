---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const blogPosts = (await getCollection('blogs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog">
  <section>
    <h1>Blog Posts</h1>
    <ul class="entry-list">
      {blogPosts.map((post) => (
        <li>
          <div class="meta">
            {post.data.sheet ?? 'BLOG'} · {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </div>
          <h3><a href={`/blogs/${post.slug}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
        </li>
      ))}
      {blogPosts.length === 0 && <li><p>No posts yet – first sheet coming soon.</p></li>}
    </ul>
  </section>
</BaseLayout>
